# bashkit/lib/logging/log-colors-symbols.sh
#
# Duplicate declarations commented out are used to provide IDE tooltip descriptions of the declaration.
# More information can be provided, however for most the definition is sufficient.
#
# shellcheck shell=bash disable=SC2034

declare -r __bashkit_lib_logging_symbols_sourced="true"

###############
### Symbols ###
###############

# declare -r SYMBOL_SUCCEEDED="${GREEN}\u2713${RESET}"
#
#   * Example: ✓ succeeded
#
declare -r SYMBOL_SUCCEEDED="${GREEN}\u2713${RESET}"

# declare -r SYMBOL_FAILED="${RED}\u2717${RESET}"
#
#   * Example: ✗ failed
#
declare -r SYMBOL_FAILED="${RED}\u2717${RESET}"

# declare -r SYMBOL_CAUTION="${YELLOW}\u26A0${RESET}"
#
#   * Example: ⚠ warning
#
declare -r SYMBOL_CAUTION="${YELLOW}\u26A0${RESET}"

# declare -r SYMBOL_BULLET_POINT="${CYAN}\u25CF${RESET}"
#
declare -r SYMBOL_BULLET_POINT="${CYAN}\u25CF${RESET}"

# declare -r SYMBOL_SKIPPED="${MAGENTA}\u2298${RESET}"
#
#   * Example: ⊘ — e.g. secret already exists, disabled_apps
#
declare -r SYMBOL_SKIPPED="\u2298"

# declare -r SYMBOL_DEBUG="${MAGENTA}\u2699${RESET}"
#
#   * Example: ⚙ — DEBUG=true / VERBOSE=1 log lines
#
declare -r SYMBOL_DEBUG="\u2699"

# declare -r SYMBOL_STEP="${BLUE}\u2192${RESET}"
#
#   * Example: → — step/stage markers in multi-step pipelines
#
declare -r SYMBOL_STEP="${BLUE}\u2192${RESET}"

# declare -r SYMBOL_IN_PROGRESS="${BLUE}\u27F3${RESET}"
#
#   * Example: ⟳ clockwise gapped circle arrow
#
declare -r SYMBOL_IN_PROGRESS="${BLUE}\u27F3${RESET}"

# declare -r SYMBOL_PENDING="${BLUE}\u23F3${RESET}"
#
#   * Example: ⏳ hourglass (flowing)
#
declare -r SYMBOL_PENDING="${BLUE}\u23F3${RESET}"

# declare -r -a SYMBOL_SPINNER_FRAMES — braille dots spinner (10 frames)
#
#   * Example: ⠋ ⠙ ⠹ ⠸ ⠼ ⠴ ⠦ ⠧ ⠇ ⠏
#
declare -r -a SYMBOL_SPINNER_FRAMES=(
    "\u280B" "\u2819" "\u2839" "\u2838" "\u283C"
    "\u2834" "\u2826" "\u2827" "\u2807" "\u280F"
)

# declare -r -a SYMBOL_SPINNER_FRAMES_SIMPLE — circle-quarters spinner (4 frames)
#
#   * Example: ◐ ◓ ◑ ◒
#
declare -r -a SYMBOL_SPINNER_FRAMES_SIMPLE=("\u25D0" "\u25D3" "\u25D1" "\u25D2")
