# shellcheck shell=bash disable=SC2034

declare -r __bashkit_lib_logging_error_messages_sourced="true"

######################
### Error Messages ###
######################

# declare -r ERROR_FILE_NOT_FOUND="${SYMBOL_FAILED} failed to find file"
#
declare -r ERROR_FILE_NOT_FOUND="${SYMBOL_FAILED} failed to find file"

# declare -r ERROR_DIR_NOT_FOUND="${SYMBOL_FAILED} directory not found"
#
declare -r ERROR_DIR_NOT_FOUND="${SYMBOL_FAILED} directory not found"

# declare -r ERROR_FAILED_TO_CREATE_DIR="${SYMBOL_FAILED} failed to create directory"
#
declare -r ERROR_FAILED_TO_CREATE_DIR="${SYMBOL_FAILED} failed to create directory"

# declare -r ERROR_FAILED_TO_CREATE_FILE="${SYMBOL_FAILED} failed to create file"
#
declare -r ERROR_FAILED_TO_CREATE_FILE="${SYMBOL_FAILED} failed to create file"

# declare -r ERROR_FILE_SOURCE_FAILED="${SYMBOL_FAILED} failed to source file"
#
declare -r ERROR_FILE_SOURCE_FAILED="${SYMBOL_FAILED} failed to source file"

# declare -r ERROR_OPTION_REQUIRED="${SYMBOL_FAILED} option must be provided"
#
declare -r ERROR_OPTION_REQUIRED="${SYMBOL_FAILED} option must be provided"

declare -r ERROR_OPTION_UNKNOWN="${SYMBOL_FAILED} option is unknown"

# declare -r ERROR_ARG_REQUIRED="${SYMBOL_FAILED} argument must be provided"
#
declare -r ERROR_ARG_REQUIRED="${SYMBOL_FAILED} argument must be provided"

# declare -r ERROR_STRING_EMPTY="${SYMBOL_FAILED} string is empty"
#
declare -r ERROR_STRING_EMPTY="${SYMBOL_FAILED} string is empty"

# declare -r ERROR_STDIN_NULL="${SYMBOL_FAILED} stdin cannot be null"
#
declare -r ERROR_STDIN_NULL="${SYMBOL_FAILED} stdin cannot be null"
