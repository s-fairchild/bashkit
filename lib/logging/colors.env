# shellcheck shell=bash disable=SC2034

declare -r __bashkit_lib_logging_colors_sourced="true"

##############
### Colors ###
##############

if [ -t 1 ]; then
    GREEN=$'\033[32m'
    GREEN=$'\033[32m'
    RED=$'\033[31m'
    YELLOW=$'\033[33m'

    CYAN=$'\033[36m'
    CYAN_BRIGHT=$'\033[96m'
    CYAN_BOLD=$'\033[1;36m'
    BLUE=$'\033[34m'

    RESET=$'\033[0m'
else
    GREEN=''
    RED=''
    YELLOW=''
    RESET=''
fi
